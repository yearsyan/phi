{
  "name": "@phi/pi-daemon",
  "version": "0.1.0",
  "description": "Phi daemon wire-compatible server backed by the Pi coding-agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pi-daemon": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev": "tsup --watch --onSuccess 'node dist/cli.js'",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "phi",
    "pi",
    "coding-agent",
    "daemon",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.81.1",
    "@earendil-works/pi-ai": "^0.81.1",
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "typebox": "1.1.38",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
