# OpenAI Chat Completions-compatible endpoint configuration.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://provider.example/v1
LLM_MODEL=model-name
LLM_MAX_CONTEXT_TOKENS=128000
LLM_MAX_OUTPUT_TOKENS=4096
LLM_TEMPERATURE=0.2
# Number of retries after the initial HTTP request fails.
LLM_MAX_RETRIES=10
# Timeout for connecting and receiving response headers.
LLM_REQUEST_TIMEOUT_SECS=30
# Maximum idle time between complete SSE events after the response starts.
LLM_STREAM_IDLE_TIMEOUT_SECS=120
# Optional; model support varies: none, minimal, low, medium, high, xhigh, max.
# LLM_REASONING_EFFORT=medium
# Optional persistent conversation session.
# LLM_SESSION_ID=demo-session
# LLM_SESSION_DIR=.phi/sessions

# Optional phi-daemon listener; loopback-only by default.
# PHI_DAEMON_BIND=127.0.0.1:8787
# PHI_DAEMON_DATA_DIR=.phi/daemon
# Skills default to ~/.phy/skills plus .phy/skills and .claude/skills under
# the daemon workspace. Each *_DIRS value is an OS-native path list.
# PHI_DAEMON_SKILLS_ENABLED=true
# PHI_DAEMON_WORKSPACE_DIR=/absolute/path/to/workspace
# PHI_DAEMON_GLOBAL_SKILLS_DIRS=/home/user/.phy/skills:/opt/company/skills
# PHI_DAEMON_WORKSPACE_SKILLS_DIRS=.phy/skills:.claude/skills
# Required by phi-daemon. The file must contain a strong bearer key; keep it
# outside version control and restrict it to the daemon user (chmod 600).
# PHI_DAEMON_AUTH_KEY_FILE=.phi/daemon/auth.key
# phi-daemon Provider credentials/settings are configured through
# PUT http://127.0.0.1:8787/v1/provider, not environment variables.
